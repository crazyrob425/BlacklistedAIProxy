# BlacklistedAIProxy — environment variable reference
#
# Copy this file to .env and fill in the values you need.
# The proxy also reads most settings from configs/config.json, which takes
# precedence.  Environment variables listed here are supplementary/override
# mechanisms that are not covered by config.json.
#
# IMPORTANT: never commit your real .env file — it is gitignored.

# ── Server (also settable in configs/config.json) ────────────────────────────

# TCP port the proxy listens on (default: 3000)
# SERVER_PORT=3000

# Bind address (default: 0.0.0.0)
# HOST=0.0.0.0

# API key callers must supply in the Authorization: Bearer header (default: 123456)
# REQUIRED_API_KEY=change-me-before-deploying

# Management port used by the master process (default: 3100)
# MASTER_PORT=3100

# ── Observability — OpenTelemetry ─────────────────────────────────────────────
#
# All OTel settings default to no-op; set OTEL_ENABLED=true to activate.

# Enable distributed tracing (default: false)
# OTEL_ENABLED=true

# Service name shown in traces (default: blacklisted-ai-proxy)
# OTEL_SERVICE_NAME=blacklisted-ai-proxy

# OTLP-HTTP collector base URL (default: http://localhost:4318)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# OTel SDK log level: none | error | warn | info | debug (default: warn)
# OTEL_LOG_LEVEL=warn

# ── Observability — Langfuse ──────────────────────────────────────────────────
#
# Langfuse is disabled unless BOTH keys are set.

# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...

# Langfuse instance URL (default: https://cloud.langfuse.com)
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── TLS sidecar ───────────────────────────────────────────────────────────────
#
# The Go TLS sidecar is only started when TLS_SIDECAR_ENABLED=true in
# configs/config.json.  This env var overrides the port at runtime.

# Port the TLS sidecar listens on (default: 9090)
# TLS_SIDECAR_PORT=9090

# ── Provider-specific debugging ───────────────────────────────────────────────

# Grok: log the raw last SSE chunk for debugging stream termination (default: false)
# GROK_LOG_LAST_CHUNK=false

# Grok: log token-usage estimates from Grok responses (default: false)
# GROK_LOG_USAGE=false

# Grok: disable client-side usage estimates (use upstream values only, default: false)
# GROK_DISABLE_USAGE_ESTIMATE=false

# OpenAI Responses API: override the max-tokens cap applied to reasoning models
# OPENAI_REASONING_MAX_TOKENS=32000

# Codex: enable the system-instructions injection feature (default: false)
# CODEX_INSTRUCTIONS_ENABLED=false

# ── Internal (set automatically — do not override) ────────────────────────────

# Set to "true" by the master process when spawning the worker; do not set manually.
# IS_WORKER_PROCESS=true
